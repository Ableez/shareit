# Convex (filled in by `npx convex dev`)
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Better Auth (run: npx convex env set BETTER_AUTH_SECRET $(openssl rand -base64 32))
SITE_URL=http://localhost:3000
BETTER_AUTH_SECRET=

# AWS / S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# Resend
RESEND_API_KEY=
EMAIL_FROM=Shareit <notify@shareit.app>

# MCP
MCP_MAX_TRANSFER_BYTES=26214400

# Web Push (VAPID)
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@shareit.app
